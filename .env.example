# Agent-side local config (never commit `.env`).
# Provider keys belong in `.env.gateway` and are loaded only by the gateway process.

OPTIMUS_PRODUCTION_MODE=false
OPTIMUS_GATEWAY_URL=http://127.0.0.1:8765
OPTIMUS_API_KEY=replace-with-local-shared-secret
OPTIMUS_REDIS_URL=redis://127.0.0.1:6379/0
OPTIMUS_AGENT_MODEL=claude-haiku
