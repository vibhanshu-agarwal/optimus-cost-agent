# Gateway-side local config (never commit `.env.gateway`).
# Loaded only by `tools/run_local_gateway.*` and the live gateway subprocess in tests.

OPTIMUS_LOCAL_GATEWAY_PROVIDER=openrouter
OPTIMUS_LOCAL_GATEWAY_PROVIDER_API_KEY=replace-with-your-openrouter-key
OPTIMUS_LOCAL_GATEWAY_SHARED_SECRET=replace-with-local-shared-secret

# Optional overrides:
# OPTIMUS_LOCAL_GATEWAY_BIND_HOST=127.0.0.1
# OPTIMUS_LOCAL_GATEWAY_PORT=8765
# OPTIMUS_LOCAL_GATEWAY_BASE_URL=https://openrouter.ai/api/v1

# Anthropic-native path (secondary):
# OPTIMUS_LOCAL_GATEWAY_PROVIDER=anthropic
# ANTHROPIC_API_KEY=replace-with-your-anthropic-key
